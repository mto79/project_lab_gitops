{% if gitops_tool == 'fluxcd' %}
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: apps-prod
  namespace: {{ flux_namespace }}
spec:
  interval: 5m0s
  path: ./apps/overlays/prod
  prune: true
  sourceRef:
    kind: GitRepository
    name: {{ project_name }}-gitops
  targetNamespace: prod
{% endif %}
