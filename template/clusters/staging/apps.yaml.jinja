{% if gitops_tool == 'fluxcd' %}
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: apps-staging
  namespace: {{ flux_namespace }}
spec:
  interval: 5m0s
  path: ./apps/overlays/staging
  prune: true
  sourceRef:
    kind: GitRepository
    name: {{ project_name }}-gitops
  targetNamespace: staging
{% endif %}
