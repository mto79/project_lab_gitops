{% if gitops_tool == 'argocd' %}
# ArgoCD ApplicationSet — generates one Application per environment
apiVersion: argoproj.io/v1alpha1
kind: ApplicationSet
metadata:
  name: {{ project_name }}
  namespace: {{ argocd_namespace }}
spec:
  generators:
    - list:
        elements:
{% for env in environments %}
          - env: {{ env }}
{% endfor %}
  template:
    metadata:
      name: "{{ project_name }}-{% raw %}{{env}}{% endraw %}"
    spec:
      project: default
      source:
        repoURL: https://github.com/mto79/{{ project_name }}-gitops
        targetRevision: main
        path: "apps/overlays/{% raw %}{{env}}{% endraw %}"
      destination:
        server: https://kubernetes.default.svc
        namespace: "{% raw %}{{env}}{% endraw %}"
      syncPolicy:
        automated:
          prune: true
          selfHeal: true
        syncOptions:
          - CreateNamespace=true
{% else %}
# FluxCD base Kustomization
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
resources: []
{% endif %}
