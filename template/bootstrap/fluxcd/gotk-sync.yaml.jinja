{% if gitops_tool == 'fluxcd' %}
apiVersion: source.toolkit.fluxcd.io/v1
kind: GitRepository
metadata:
  name: {{ project_name }}-gitops
  namespace: {{ flux_namespace }}
spec:
  interval: 1m0s
  ref:
    branch: main
  url: https://github.com/mto79/{{ project_name }}-gitops
---
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: apps
  namespace: {{ flux_namespace }}
spec:
  interval: 10m0s
  path: ./clusters/dev
  prune: true
  sourceRef:
    kind: GitRepository
    name: {{ project_name }}-gitops
{% endif %}
